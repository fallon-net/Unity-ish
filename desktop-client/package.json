{
    "name": "unity-ish-desktop-client",
    "version": "0.1.0",
    "private": true,
    "main": "electron/main.cjs",
    "type": "module",
    "scripts": {
        "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
        "dev:renderer": "vite --host 0.0.0.0 --port 5174",
        "dev:electron": "wait-on tcp:5174 && electron .",
        "typecheck": "tsc --noEmit",
        "build": "npm run typecheck && vite build",
        "start": "electron ."
    },
    "dependencies": {
        "livekit-client": "^2.15.7",
        "react": "^18.3.1",
        "react-dom": "^18.3.1"
    },
    "devDependencies": {
        "@types/node": "^22.10.1",
        "@types/react": "^18.3.12",
        "@types/react-dom": "^18.3.1",
        "@vitejs/plugin-react": "^4.3.4",
        "concurrently": "^9.1.0",
        "electron": "^33.2.1",
        "typescript": "^5.7.2",
        "vite": "^5.4.21",
        "wait-on": "^8.0.1"
    }
}